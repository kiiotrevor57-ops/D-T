<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>CPSCMS · Nakuru County Pharmaceutical Management System</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Serif:wght@500;600;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --red:#CC1F2D;--red-d:#A8181F;--red-bg:#FBE9EA;--red-br:#E8AAAD;
  --gold:#C8991A;--gold-bg:#FBF4E0;--gold-br:#DFC878;
  --green:#2E7D2E;--green-bg:#E6F2E6;--green-br:#90C490;
  --blue:#1A6FAF;--blue-bg:#E3EFF9;--blue-br:#A8CDE8;
  --sb:#1A1A1A;--navy:#1C1C1C;--slate:#3D4A52;--steel:#6B7880;--mist:#9AAAB5;
  --silver:#DDE3E8;--paper:#F4F5F6;--white:#FFF;
  --border:#D4DADF;--border-s:#B8C2CA;
  --text:#1A1A1A;--text2:#3D4A52;--text3:#6B7880;
  --bg:#F2F3F4;--card:#FFF;
  --xs:0 1px 2px rgba(26,26,26,.06);
  --sm:0 2px 6px rgba(26,26,26,.09);
  --md:0 4px 16px rgba(26,26,26,.11);
  --lg:0 8px 32px rgba(26,26,26,.15);
  --r:8px;--rs:5px;--sw:256px;
}
html,body{height:100%;overflow:hidden;}
body{font-family:'IBM Plex Sans',sans-serif;background:var(--bg);color:var(--text);display:flex;font-size:13px;line-height:1.5;}

/* SIDEBAR */
.sb{width:var(--sw);min-height:100vh;background:var(--sb);position:fixed;left:0;top:0;bottom:0;z-index:200;display:flex;flex-direction:column;transition:transform .25s;}
.sb::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--red) 60%,var(--gold));z-index:1;}
.sb-brand{padding:16px 18px 14px;border-bottom:1px solid rgba(255,255,255,.07);margin-top:3px;background:rgba(204,31,45,.06);}
.sb-logo{display:flex;align-items:center;gap:12px;}
.sb-crest{width:40px;height:40px;flex-shrink:0;}
.sb-county{font-family:'IBM Plex Serif',serif;font-size:13px;font-weight:600;color:#fff;line-height:1.2;}
.sb-sys{font-size:9px;font-weight:500;letter-spacing:1.2px;text-transform:uppercase;color:var(--mist);margin-top:3px;}
.sb-roletag{margin:10px 12px;padding:5px 10px;border-radius:var(--rs);background:rgba(204,31,45,.15);border:1px solid rgba(204,31,45,.28);font-size:9px;font-weight:700;letter-spacing:.8px;color:#F4A0A6;text-transform:uppercase;}
.sb-nav{flex:1;padding:8px 10px;overflow-y:auto;}
.sb-nav::-webkit-scrollbar{width:3px;}
.sb-nav::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:3px;}
.nav-sec{font-size:9px;font-weight:600;letter-spacing:1.4px;text-transform:uppercase;color:rgba(255,255,255,.22);padding:14px 8px 5px;display:block;}
.nav-item{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:var(--rs);cursor:pointer;margin-bottom:1px;transition:background .12s;border:1px solid transparent;}
.nav-item:hover{background:rgba(255,255,255,.05);}
.nav-item.active{background:rgba(204,31,45,.14);border-color:rgba(204,31,45,.28);border-left:2px solid var(--red);padding-left:9px;}
.nav-icon{width:26px;height:26px;display:flex;align-items:center;justify-content:center;flex-shrink:0;opacity:.65;}
.nav-item.active .nav-icon,.nav-item:hover .nav-icon{opacity:1;}
.nav-icon svg{width:14px;height:14px;}
.nav-label{font-size:12px;color:rgba(255,255,255,.62);flex:1;}
.nav-item.active .nav-label{color:rgba(255,255,255,.92);font-weight:500;}
.nav-badge{font-family:'IBM Plex Mono',monospace;font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;background:var(--red);color:#fff;}
.nav-badge.w{background:#6B4800;color:#FFD060;}
.sb-foot{padding:12px;border-top:1px solid rgba(255,255,255,.07);}
.user-block{display:flex;align-items:center;gap:10px;padding:10px;border-radius:var(--rs);border:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.03);}
.user-av{width:32px;height:32px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;font-family:'IBM Plex Mono',monospace;}
.user-name{font-size:12px;font-weight:600;color:rgba(255,255,255,.88);}
.user-role-txt{font-size:10px;color:var(--mist);margin-top:1px;}

/* MAIN */
.main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;height:100vh;overflow:hidden;}
.topbar{background:var(--white);border-bottom:2px solid var(--red);height:56px;display:flex;align-items:center;padding:0 22px;z-index:100;box-shadow:var(--xs);gap:14px;flex-shrink:0;}
.tb-title{font-family:'IBM Plex Serif',serif;font-size:15px;font-weight:600;color:var(--red);letter-spacing:-.2px;white-space:nowrap;}
.tb-div{width:1px;height:20px;background:var(--border);flex-shrink:0;}
.tb-bc{font-size:11px;color:var(--text3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:9px;flex-shrink:0;}
.live-ind{display:flex;align-items:center;gap:5px;font-size:10px;font-weight:700;color:var(--green);letter-spacing:.4px;text-transform:uppercase;}
.live-dot{width:7px;height:7px;background:#2e8b57;border-radius:50%;animation:blink 2s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.clock{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);background:var(--paper);border:1px solid var(--border);padding:4px 9px;border-radius:3px;}

/* SEARCH */
.search-wrap{position:relative;}
.search-input{font-family:'IBM Plex Sans',sans-serif;font-size:12px;background:var(--paper);border:1px solid var(--border);border-radius:var(--rs);padding:6px 12px 6px 30px;width:200px;outline:none;transition:all .15s;color:var(--text);}
.search-input:focus{border-color:var(--red);background:#fff;box-shadow:0 0 0 3px rgba(204,31,45,.08);width:240px;}
.search-icon{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:var(--text3);}
.search-icon svg{width:12px;height:12px;}
.search-results{position:absolute;top:calc(100% + 6px);left:0;background:var(--white);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--md);z-index:999;display:none;min-width:300px;max-height:400px;overflow-y:auto;}
.search-results.open{display:block;}
.sr-section{padding:8px 12px 4px;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text3);border-top:1px solid var(--border);}
.sr-section:first-child{border-top:none;}
.sr-item{display:flex;align-items:center;gap:10px;padding:8px 12px;cursor:pointer;transition:background .1s;}
.sr-item:hover{background:var(--paper);}
.sr-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.sr-dot.red{background:var(--red);}
.sr-dot.gold{background:var(--gold);}
.sr-dot.green{background:var(--green);}
.sr-dot.blue{background:var(--blue);}
.sr-name{font-size:12px;font-weight:600;flex:1;}
.sr-meta{font-size:10px;color:var(--text3);}
.sr-tag{font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;font-family:'IBM Plex Mono',monospace;background:var(--paper);color:var(--text3);}

/* ICON BUTTONS */
.icon-btn{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .12s;position:relative;}
.icon-btn:hover{background:var(--paper);}
.icon-btn svg{width:15px;height:15px;color:var(--steel);}
.notif-dot{position:absolute;top:4px;right:4px;width:7px;height:7px;background:var(--red);border-radius:50%;border:2px solid #fff;}

/* CONTENT */
.content-area{flex:1;overflow-y:auto;overflow-x:hidden;}
.content-area::-webkit-scrollbar{width:5px;}
.content-area::-webkit-scrollbar-thumb{background:var(--border);border-radius:5px;}

/* PAGES */
.page{display:none;padding:22px;}
.page.active{display:block;animation:fadeUp .3s ease both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ALERT STRIP */
.alert-strip{display:flex;align-items:flex-start;gap:12px;padding:11px 15px;border-radius:var(--rs);border:1px solid var(--red-br);border-left:3px solid var(--red);background:var(--red-bg);margin-bottom:18px;font-size:12px;}
.alert-strip.warn{border-color:var(--gold-br);border-left-color:var(--gold);background:var(--gold-bg);}
.alert-strip.info{border-color:var(--blue-br);border-left-color:var(--blue);background:var(--blue-bg);}
.alert-strip strong{font-weight:700;color:var(--red);}
.alert-strip.warn strong{color:var(--gold);}
.alert-strip.info strong{color:var(--blue);}
.alert-strip p{color:var(--text2);margin-top:2px;}
.alert-icon svg{width:15px;height:15px;}

/* BUTTONS */
.btn{font-family:'IBM Plex Sans',sans-serif;font-size:12px;font-weight:600;padding:6px 14px;border-radius:var(--rs);border:1px solid transparent;cursor:pointer;transition:all .12s;display:inline-flex;align-items:center;gap:6px;white-space:nowrap;}
.btn svg{width:12px;height:12px;}
.btn-primary{background:var(--red);color:#fff;border-color:var(--red);}
.btn-primary:hover{background:var(--red-d);}
.btn-secondary{background:var(--white);color:var(--text2);border-color:var(--border);}
.btn-secondary:hover{background:var(--paper);border-color:var(--border-s);}
.btn-gold{background:var(--gold);color:#fff;border-color:var(--gold);}
.btn-danger{background:var(--red);color:#fff;}
.btn-sm{font-size:11px;padding:4px 10px;}
.btn-xs{font-size:10px;padding:3px 8px;}

/* KPI */
.kpi-row{display:grid;gap:12px;margin-bottom:18px;}
.kpi-row.c6{grid-template-columns:repeat(6,1fr);}
.kpi-row.c4{grid-template-columns:repeat(4,1fr);}
.kpi-row.c3{grid-template-columns:repeat(3,1fr);}
.kpi-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:15px 17px;box-shadow:var(--xs);position:relative;transition:box-shadow .15s,transform .15s;cursor:default;}
.kpi-card:hover{box-shadow:var(--sm);transform:translateY(-1px);}
.kpi-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:var(--r) var(--r) 0 0;background:var(--kc,var(--red));}
.kpi-card.red{--kc:var(--red);}
.kpi-card.gold{--kc:var(--gold);}
.kpi-card.green{--kc:var(--green);}
.kpi-card.blue{--kc:var(--blue);}
.kpi-card.slate{--kc:var(--steel);}
.kpi-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:9px;}
.kpi-label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text3);}
.kpi-badge{font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;font-family:'IBM Plex Mono',monospace;}
.kpi-badge.up{background:var(--green-bg);color:var(--green);}
.kpi-badge.dn{background:var(--red-bg);color:var(--red);}
.kpi-badge.wn{background:var(--gold-bg);color:var(--gold);}
.kpi-badge.fl{background:var(--paper);color:var(--text3);}
.kpi-value{font-family:'IBM Plex Serif',serif;font-size:23px;font-weight:700;color:var(--text);line-height:1;letter-spacing:-.5px;margin-bottom:4px;}
.kpi-sub{font-size:10px;color:var(--text3);border-top:1px solid var(--silver);padding-top:6px;margin-top:6px;font-family:'IBM Plex Mono',monospace;}

/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--xs);overflow:hidden;}
.card-hd{padding:12px 17px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--paper);}
.card-hd h3{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text2);}
.card-bd{padding:15px 17px;}

/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.gm{display:grid;grid-template-columns:1fr 310px;gap:14px;}
.g7030{display:grid;grid-template-columns:1fr 290px;gap:14px;}
.mb18{margin-bottom:18px;}
.mb14{margin-bottom:14px;}

/* TABLE */
.dt{width:100%;border-collapse:collapse;font-size:12px;}
.dt th{padding:8px 13px;text-align:left;background:var(--paper);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--text3);border-bottom:1px solid var(--border);white-space:nowrap;}
.dt td{padding:9px 13px;border-bottom:1px solid var(--silver);color:var(--text);vertical-align:middle;}
.dt tr:last-child td{border-bottom:none;}
.dt tbody tr{cursor:pointer;transition:background .1s;}
.dt tbody tr:hover td{background:var(--paper);}
.mono{font-family:'IBM Plex Mono',monospace;font-size:11px;}

/* STATUS */
.st{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;text-transform:uppercase;letter-spacing:.4px;font-family:'IBM Plex Mono',monospace;}
.st.critical{background:var(--red-bg);color:var(--red);border:1px solid var(--red-br);}
.st.warn{background:var(--gold-bg);color:var(--gold);border:1px solid var(--gold-br);}
.st.ok{background:var(--green-bg);color:var(--green);border:1px solid var(--green-br);}
.st.info{background:var(--blue-bg);color:var(--blue);border:1px solid var(--blue-br);}
.st.pend{background:var(--paper);color:var(--steel);border:1px solid var(--border);}
.st.draft{background:var(--blue-bg);color:var(--blue);border:1px dashed var(--blue-br);}

/* PROGRESS */
.prog{height:5px;background:var(--silver);border-radius:3px;overflow:hidden;}
.prog-b{height:100%;border-radius:3px;}
.prog-b.critical{background:var(--red);}
.prog-b.warn{background:var(--gold);}
.prog-b.ok{background:var(--green);}

/* FACILITY ROW */
.fac-row{display:flex;align-items:center;gap:11px;padding:9px 0;border-bottom:1px solid var(--silver);}
.fac-row:last-child{border-bottom:none;}
.sdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.sdot.critical{background:var(--red);}
.sdot.warn{background:var(--gold);}
.sdot.ok{background:var(--green);}
.fac-name{font-size:12px;font-weight:600;flex:1;cursor:pointer;}
.fac-name:hover{color:var(--red);}
.fac-sub{font-size:10px;color:var(--text3);margin-top:1px;}
.fac-pct{font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:600;min-width:34px;text-align:right;}
.fac-pct.critical{color:var(--red);}
.fac-pct.warn{color:var(--gold);}

/* MINI STAT */
.mstat{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--silver);font-size:12px;}
.mstat:last-child{border-bottom:none;}
.mstat .lbl{color:var(--text2);}
.mstat .val{font-family:'IBM Plex Mono',monospace;font-weight:600;}

/* SECTION HEADER */
.sec-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.sec-hd h2{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text2);}

/* SUPPLIER ROW */
.sup-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--silver);}
.sup-row:last-child{border-bottom:none;}
.sup-av{width:30px;height:30px;background:var(--red-bg);color:var(--red);border-radius:var(--rs);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;font-family:'IBM Plex Mono',monospace;flex-shrink:0;}
.sup-name{font-size:12px;font-weight:600;flex:1;}
.sup-meta{font-size:10px;color:var(--text3);}
.sup-score{font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:700;color:var(--red);}

/* TRANSFER REC */
.tr-rec{border:1px solid var(--gold-br);border-left:3px solid var(--gold);border-radius:var(--rs);background:#FFFCF0;padding:11px 13px;margin-bottom:9px;display:flex;gap:11px;align-items:flex-start;}
.tr-rec.exp{border-left-color:var(--red);border-color:var(--red-br);background:#FFFAFA;}
.tr-body{flex:1;}
.tr-title{font-size:12px;font-weight:700;margin-bottom:3px;}
.tr-sub{font-size:11px;color:var(--text2);}
.tr-flow{display:flex;align-items:center;gap:8px;margin:7px 0;font-size:11px;font-weight:600;flex-wrap:wrap;}
.tr-facility{background:var(--paper);border:1px solid var(--border);padding:3px 9px;border-radius:var(--rs);font-family:'IBM Plex Mono',monospace;font-size:10px;}
.tr-arrow{color:var(--text3);font-size:14px;}
.tr-saving{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;background:var(--green-bg);color:var(--green);border:1px solid var(--green-br);font-family:'IBM Plex Mono',monospace;}
.tr-tag{font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;background:var(--gold-bg);color:var(--gold);border:1px solid var(--gold-br);display:inline-block;margin-top:5px;font-family:'IBM Plex Mono',monospace;}
.tr-tag.exp{color:var(--red);background:var(--red-bg);border-color:var(--red-br);}

/* EXPIRY ROWS */
.eor{border:1px solid var(--border);border-radius:var(--rs);padding:10px 13px;margin-bottom:7px;display:flex;align-items:center;gap:11px;background:var(--white);transition:box-shadow .12s;}
.eor:hover{box-shadow:var(--sm);}
.eor.flagged{border-left:3px solid var(--red);background:#FFFBFB;}
.eor.expiring{border-left:3px solid var(--gold);}
.eor-body{flex:1;}
.eor-name{font-size:12px;font-weight:700;}
.eor-meta{font-size:10px;color:var(--text3);margin-top:2px;}
.eor-days{font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:700;text-align:right;}
.eor-days.critical{color:var(--red);}
.eor-days.warn{color:var(--gold);}

/* EXPIRY CALENDAR */
.exp-cal{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin-bottom:16px;}
.exp-bucket{border-radius:var(--r);padding:13px 15px;border:1px solid var(--border);}
.exp-bucket.urgent{border-color:var(--red-br);background:var(--red-bg);}
.exp-bucket.soon{border-color:var(--gold-br);background:var(--gold-bg);}
.exp-bucket.watch{background:var(--paper);}
.exp-bucket-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;}
.exp-bucket.urgent .exp-bucket-lbl{color:var(--red);}
.exp-bucket.soon .exp-bucket-lbl{color:var(--gold);}
.exp-bucket.watch .exp-bucket-lbl{color:var(--steel);}
.exp-bucket-count{font-family:'IBM Plex Serif',serif;font-size:28px;font-weight:700;margin-bottom:2px;}
.exp-bucket.urgent .exp-bucket-count{color:var(--red);}
.exp-bucket.soon .exp-bucket-count{color:var(--gold);}
.exp-bucket-sub{font-size:10px;color:var(--text3);}

/* AUDIT LOG */
.audit-row{display:flex;align-items:flex-start;gap:11px;padding:9px 0;border-bottom:1px solid var(--silver);}
.audit-row:last-child{border-bottom:none;}
.audit-time{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--text3);width:75px;flex-shrink:0;padding-top:2px;}
.audit-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.audit-dot.create{background:var(--green);}
.audit-dot.update{background:var(--blue);}
.audit-dot.approve{background:var(--gold);}
.audit-dot.login{background:var(--steel);}
.audit-dot.auto{background:var(--red);}
.audit-action{font-size:12px;font-weight:600;}
.audit-detail{font-size:11px;color:var(--text2);margin-top:1px;}
.audit-user{font-size:10px;color:var(--text3);font-style:italic;margin-top:2px;}

/* MAP */
.map-container{position:relative;background:#F7F8F9;border-radius:var(--r);border:1px solid var(--border);overflow:hidden;height:420px;}
.map-tooltip{position:absolute;background:var(--navy);color:#fff;padding:10px 13px;border-radius:var(--rs);font-size:11px;pointer-events:none;opacity:0;transition:opacity .15s;z-index:10;min-width:190px;box-shadow:var(--md);}
.map-tooltip.show{opacity:1;}
.map-legend{display:flex;gap:14px;padding:10px 15px;background:var(--paper);border-top:1px solid var(--border);flex-wrap:wrap;}
.ml-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text2);}
.ml-dot{width:9px;height:9px;border-radius:50%;}
.facility-dot{cursor:pointer;transition:r .15s;}
.facility-dot:hover{opacity:.75;}

/* CHART */
.chart-tabs{display:flex;gap:4px;margin-bottom:12px;}
.chart-tab{font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;padding:4px 11px;border-radius:3px;border:1px solid var(--border);background:var(--white);cursor:pointer;color:var(--text3);transition:all .12s;}
.chart-tab.active{background:var(--red);color:#fff;border-color:var(--red);}

/* BAR CHART */
.bar-chart{display:flex;align-items:flex-end;gap:5px;height:130px;padding-top:12px;}
.bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;}
.bar{width:100%;border-radius:3px 3px 0 0;cursor:pointer;transition:opacity .12s;}
.bar:hover{opacity:.75;}
.bar-lbl{font-size:9px;color:var(--text3);text-align:center;font-family:'IBM Plex Mono',monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;}
.bar-val{font-size:8px;font-weight:700;color:var(--text2);font-family:'IBM Plex Mono',monospace;}

/* DONUT */
.donut-wrap{display:flex;align-items:center;gap:18px;}
.donut-legend{display:flex;flex-direction:column;gap:7px;}
.dl-item{display:flex;align-items:center;gap:7px;font-size:11px;}
.dl-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.dl-label{color:var(--text2);flex:1;}
.dl-val{font-family:'IBM Plex Mono',monospace;font-weight:600;color:var(--text);}

/* FACILITY DETAIL */
.back-btn{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--text3);cursor:pointer;margin-bottom:14px;transition:color .12s;}
.back-btn:hover{color:var(--red);}
.back-btn svg{width:13px;height:13px;}
.fac-header{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;margin-bottom:14px;display:flex;align-items:flex-start;gap:18px;box-shadow:var(--xs);}
.fac-hd-info{flex:1;}
.fac-hd-title{font-family:'IBM Plex Serif',serif;font-size:19px;font-weight:600;color:var(--text);margin-bottom:3px;}
.fac-hd-meta{font-size:12px;color:var(--text3);}
.fac-hd-stats{display:flex;gap:18px;margin-top:11px;}
.fhs{text-align:center;}
.fhs-val{font-family:'IBM Plex Mono',monospace;font-size:15px;font-weight:700;color:var(--text);}
.fhs-lbl{font-size:9px;color:var(--text3);margin-top:2px;text-transform:uppercase;letter-spacing:.5px;}

/* EXPORT BAR */
.export-bar{display:flex;align-items:center;gap:8px;padding:8px 0;margin-bottom:8px;}
.export-bar span{font-size:11px;color:var(--text3);margin-right:4px;}

/* NOTIFICATION PANEL */
.notif-panel{position:fixed;top:0;right:0;width:370px;height:100vh;background:var(--white);box-shadow:var(--lg);z-index:500;transform:translateX(100%);transition:transform .25s;display:flex;flex-direction:column;border-left:1px solid var(--border);}
.notif-panel.open{transform:translateX(0);}
.np-hd{padding:15px 17px;border-bottom:1px solid var(--border);background:var(--paper);display:flex;align-items:center;justify-content:space-between;}
.np-hd h3{font-size:13px;font-weight:700;color:var(--text);}
.np-tabs{display:flex;border-bottom:1px solid var(--border);background:var(--white);}
.np-tab{font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;padding:8px 14px;border:none;background:none;cursor:pointer;color:var(--text3);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .12s;}
.np-tab.active{color:var(--red);border-bottom-color:var(--red);font-weight:700;}
.np-body{flex:1;overflow-y:auto;padding:10px;}
.np-body::-webkit-scrollbar{width:3px;}
.np-body::-webkit-scrollbar-thumb{background:var(--border);}
.notif-item{display:flex;gap:11px;padding:10px 11px;border-radius:var(--rs);margin-bottom:5px;border:1px solid var(--border);cursor:pointer;transition:background .1s;}
.notif-item:hover{background:var(--paper);}
.notif-item.unread{background:var(--red-bg);border-color:var(--red-br);}
.notif-item.unread.warn-n{background:var(--gold-bg);border-color:var(--gold-br);}
.notif-item.unread.info-n{background:var(--blue-bg);border-color:var(--blue-br);}
.ni-icon{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.ni-icon.red{background:var(--red-bg);}
.ni-icon.gold{background:var(--gold-bg);}
.ni-icon.blue{background:var(--blue-bg);}
.ni-icon svg{width:13px;height:13px;}
.ni-title{font-size:12px;font-weight:700;margin-bottom:2px;}
.ni-msg{font-size:11px;color:var(--text2);}
.ni-meta{font-size:10px;color:var(--text3);margin-top:3px;font-family:'IBM Plex Mono',monospace;}
.ni-actions{display:flex;gap:5px;margin-top:7px;}
.np-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.18);z-index:499;}
.np-overlay.open{display:block;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(15,15,15,.52);z-index:1000;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--white);border-radius:var(--r);width:560px;max-height:88vh;overflow-y:auto;box-shadow:var(--lg);border:1px solid var(--border);}
.modal-hd{padding:15px 21px;border-bottom:1px solid var(--border);background:var(--paper);display:flex;align-items:center;justify-content:space-between;}
.modal-hd h2{font-family:'IBM Plex Serif',serif;font-size:15px;font-weight:600;color:var(--navy);}
.close-btn{width:26px;height:26px;border-radius:var(--rs);border:1px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--text3);}
.modal-bd{padding:19px 21px;}
.modal-note{font-size:11px;color:var(--text2);margin-bottom:15px;padding:9px 12px;background:var(--blue-bg);border:1px solid var(--blue-br);border-radius:var(--rs);}
.form-row{margin-bottom:13px;}
.form-row label{display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--text2);margin-bottom:4px;}
.form-row input,.form-row select,.form-row textarea{width:100%;font-family:'IBM Plex Sans',sans-serif;font-size:12px;padding:7px 11px;border:1px solid var(--border);border-radius:var(--rs);background:var(--white);color:var(--text);outline:none;transition:border-color .12s;}
.form-row input:focus,.form-row select:focus,.form-row textarea:focus{border-color:var(--red);box-shadow:0 0 0 3px rgba(204,31,45,.08);}
.form-row input[readonly]{background:var(--paper);color:var(--text3);}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.modal-ft{padding:13px 21px;border-top:1px solid var(--border);display:flex;gap:7px;justify-content:flex-end;background:var(--paper);}

/* INTERFACE SWITCHER */
.ifsw{position:fixed;bottom:18px;right:18px;z-index:9999;background:var(--sb);border-radius:var(--r);padding:10px;box-shadow:var(--lg);border:1px solid rgba(255,255,255,.07);}
.ifsw-lbl{font-size:8px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--mist);margin-bottom:6px;text-align:center;}
.ifsw-btns{display:flex;flex-direction:column;gap:3px;}
.sw-btn{font-family:'IBM Plex Sans',sans-serif;font-size:10px;font-weight:500;padding:5px 12px;border-radius:var(--rs);border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.04);color:rgba(255,255,255,.60);cursor:pointer;transition:all .12s;text-align:left;}
.sw-btn:hover{background:rgba(255,255,255,.09);color:#fff;}
.sw-btn.active{background:var(--red);border-color:var(--red);color:#fff;}

/* TOAST */
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);padding:10px 20px;border-radius:var(--r);font-size:12px;font-weight:600;z-index:9999;box-shadow:var(--md);pointer-events:none;animation:toastAnim .3s ease;}
@keyframes toastAnim{from{opacity:0;transform:translateX(-50%) translateY(10px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

/* MOBILE */
@media(max-width:768px){
  .sb{transform:translateX(-100%);}
  .sb.mob-open{transform:translateX(0);}
  .main{margin-left:0;}
  .kpi-row.c6{grid-template-columns:repeat(2,1fr);}
  .kpi-row.c4{grid-template-columns:repeat(2,1fr);}
  .g2,.g3,.gm,.g7030{grid-template-columns:1fr;}
  .search-input{width:140px;}
  .ifsw{display:none;}
  .page{padding:12px;}
  .topbar{padding:0 12px;gap:8px;}
  .tb-bc{display:none;}
  .tb-title{font-size:13px;}
  .mob-menu-btn{display:flex!important;}
  .exp-cal{grid-template-columns:1fr;}
}
.mob-menu-btn{display:none;width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--border);background:var(--white);cursor:pointer;align-items:center;justify-content:center;}
.mob-menu-btn svg{width:15px;height:15px;color:var(--steel);}
.mob-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:199;}
.mob-overlay.open{display:block;}
</style>
</head>
<body>

