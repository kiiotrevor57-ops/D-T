// ─── CLOCK ───────────────────────────────────────────────────────────
function tick(){
  const n=new Date();
  document.getElementById('clock').textContent=n.toLocaleTimeString('en-KE',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false})+' EAT';
  const dt=n.toLocaleString('en-KE',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit',hour12:false});
  const el=document.getElementById('issue-dt');
  if(el) el.value=dt;
}
tick(); setInterval(tick,1000);

// ─── BUILD NAV ───────────────────────────────────────────────────────
function buildNav(key){
  const c=NAVS[key];
  let h=`<div class="sb-roletag">${c.role}</div>`;
  c.nav.forEach(item=>{
    if(item.s){h+=`<span class="nav-sec">${item.s}</span>`;return;}
    const badge=item.b?`<span class="nav-badge${item.bw?' w':''}">${item.b}</span>`:'';
    const click=item.p?`onclick="goPage('${item.p}')"`:''
    h+=`<div class="nav-item${item.a?' active':''}" ${click}><span class="nav-icon">${IC[item.i]||''}</span><span class="nav-label">${item.l}</span>${badge}</div>`;
  });
  return h;
}

// ─── INTERFACE SWITCH ────────────────────────────────────────────────
function switchIface(key,btn){
  const c=NAVS[key];
  document.getElementById('sb-nav').innerHTML=buildNav(key);
  document.getElementById('tb-title').textContent=c.title;
  document.getElementById('tb-bc').textContent=c.bc;
  document.getElementById('user-av').textContent=c.user.av;
  document.getElementById('user-name').textContent=c.user.name;
  document.getElementById('user-role').textContent=c.user.role;
  document.querySelectorAll('.sw-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  const def=c.nav.find(n=>n.a&&n.p);
  goPage(def?def.p:'page-dashboard');
}

// ─── PAGE NAV ────────────────────────────────────────────────────────
function goPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const p=document.getElementById(id);
  if(p){p.classList.add('active');}
  document.getElementById('content-area').scrollTop=0;
  document.querySelectorAll('.nav-item').forEach(n=>{
    n.classList.remove('active');
    const oc=n.getAttribute('onclick')||'';
    if(oc.includes(id)) n.classList.add('active');
  });
  if(id==='page-facilities') renderFacilities();
  if(id==='page-map') renderMap();
  if(id==='page-audit') renderAudit();
}

// ─── FACILITY DETAIL ─────────────────────────────────────────────────
function goFacilityDetail(name){
  const info=FAC_INFO[name]||{type:'Health Facility',sub:'Nakuru County',lvl:'Level 3'};
  const stock=FAC_STOCK[name]||FAC_STOCK['Nakuru Level 5 Hospital'];
  const fac=FACILITIES.find(f=>f.name===name)||FACILITIES[0];
  const cl=fac.status==='critical'?'critical':fac.status==='warn'?'warn':'ok';
  const stlbl=fac.status==='critical'?'CRITICAL':fac.status==='warn'?'LOW STOCK':'ADEQUATE';
  document.getElementById('fac-detail-hdr').innerHTML=`
    <div class="fac-hd-info">
      <div class="fac-hd-title">${name}</div>
      <div class="fac-hd-meta">${info.type} · ${info.sub} · ${info.lvl}</div>
      <div class="fac-hd-stats">
        <div class="fhs"><div class="fhs-val ${fac.status==='critical'?'":"style="color:var(--red)"':fac.status==='warn'?'style="color:var(--gold)"':''}>${fac.pct}%</div><div class="fhs-lbl">Stock Level</div></div>
        <div class="fhs"><div class="fhs-val">${stock.length}</div><div class="fhs-lbl">Medicine Lines</div></div>
        <div class="fhs"><div class="fhs-val" style="color:${fac.critical>0?'var(--red)':'var(--green)'}">${fac.critical}</div><div class="fhs-lbl">Critical Items</div></div>
        <div class="fhs"><div class="fhs-val" style="font-size:12px">${fac.updated}</div><div class="fhs-lbl">Last Updated</div></div>
      </div>
    </div>
    <span class="st ${cl}" style="font-size:10px;padding:5px 11px">${stlbl}</span>`;
  document.getElementById('fi-type').textContent=info.type;
  document.getElementById('fi-sub').textContent=info.sub;
  document.getElementById('fi-lvl').textContent=info.lvl;
  document.getElementById('tr-dest').textContent=name;
  document.getElementById('tr-src2').textContent=name;
  document.getElementById('fac-detail-tbody').innerHTML=stock.map(s=>`
    <tr>
      <td><strong>${s.name}</strong></td>
      <td>${s.unit}</td>
      <td class="mono">${s.qty.toLocaleString()}</td>
      <td class="mono">${s.monthly.toLocaleString()}/mo</td>
      <td class="mono" style="color:var(--${s.status==='critical'?'red':s.status==='warn'?'gold':'green'})">${s.days} days</td>
      <td class="mono">${s.expiry}</td>
      <td><span class="st ${s.status==='critical'?'critical':s.status==='warn'?'warn':'ok'}">${s.status==='critical'?'Critical':s.status==='warn'?'Low':'Adequate'}</span></td>
      <td><button class="btn btn-xs btn-secondary" onclick="openModal('modal-transfer')">Transfer</button></td>
    </tr>`).join('');
  goPage('page-fac-detail');
}

