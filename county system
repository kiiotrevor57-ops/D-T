    {x:240,y:290,name:'Njoro Health Centre',pct:33,status:'warn'},
    {x:190,y:330,name:'Molo Dispensary',pct:22,status:'warn'},
    {x:375,y:298,name:'Subukia Dispensary',pct:41,status:'ok'},
    {x:428,y:270,name:'Rongai Health Centre',pct:58,status:'ok'},
  ];
  const colorMap={critical:'#CC1F2D',warn:'#C8991A',ok:'#2E7D2E'};
  // Seed-based pseudorandom for consistent extra dots
  const extras=[];
  let seed=42;
  function rng(){seed=(seed*1664525+1013904223)&0xffffffff;return(seed>>>0)/4294967296;}
  for(let i=0;i<26;i++){
    const x=130+rng()*450; const y=60+rng()*300;
    const r=rng(); const status=r<0.09?'critical':r<0.24?'warn':'ok';
    extras.push({x,y,status,name:`Sub-County Facility #${i+20}`,pct:status==='critical'?Math.floor(rng()*14)+1:status==='warn'?Math.floor(rng()*20)+15:Math.floor(rng()*55)+40});
  }
  const all=[...main,...extras];
  svg.innerHTML=`
    <path d="M115,75 L275,38 L435,55 L575,115 L635,230 L595,335 L495,395 L355,415 L215,375 L118,298 L78,195 Z" fill="rgba(26,111,175,.04)" stroke="#B8C2CA" stroke-width="1.5"/>
    <text x="200" y="165" font-size="11" fill="#6B7880" font-family="IBM Plex Sans,sans-serif" font-weight="600">Nakuru Town</text>
    <text x="360" y="90" font-size="11" fill="#6B7880" font-family="IBM Plex Sans,sans-serif" font-weight="600">Naivasha</text>
    <text x="478" y="142" font-size="11" fill="#6B7880" font-family="IBM Plex Sans,sans-serif" font-weight="600">Gilgil</text>
    <text x="270" y="375" font-size="11" fill="#6B7880" font-family="IBM Plex Sans,sans-serif" font-weight="600">South Rift</text>
    ${all.map((d,i)=>`<circle class="facility-dot" cx="${d.x.toFixed(1)}" cy="${d.y.toFixed(1)}" r="${i<12?7:4.5}" fill="${colorMap[d.status]}" opacity="${i<12?1:.75}" stroke="white" stroke-width="${i<12?2:1.2}" data-i="${i}"/>`).join('')}`;
  svg.querySelectorAll('.facility-dot').forEach((dot,i)=>{
    const d=all[i];
    dot.addEventListener('mouseenter',e=>{
      const rect=document.getElementById('map-container').getBoundingClientRect();
      const scolor=d.status==='critical'?'#ff8a8a':d.status==='warn'?'#ffd060':'#80dd80';
      tooltip.innerHTML=`<div style="font-weight:700;margin-bottom:4px;font-size:12px">${d.name}</div><div style="font-size:11px;color:#9AAAB5">Stock: <span style="color:#fff;font-family:IBM Plex Mono,monospace">${d.pct}%</span></div><div style="margin-top:5px;font-size:9px;font-weight:700;color:${scolor}">${d.status==='critical'?'● CRITICAL':d.status==='warn'?'● LOW STOCK':'● ADEQUATE'}</div>`;
      let tx=e.clientX-rect.left+14, ty=e.clientY-rect.top-10;
      if(tx>rect.width-220) tx=e.clientX-rect.left-210;
      tooltip.style.left=tx+'px'; tooltip.style.top=ty+'px';
      tooltip.classList.add('show');
    });
    dot.addEventListener('mouseleave',()=>tooltip.classList.remove('show'));
    dot.addEventListener('click',()=>{
      tooltip.classList.remove('show');
      if(FAC_INFO[d.name]) goFacilityDetail(d.name);
      else goFacilityDetail(main[0].name);
    });
  });
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────
function renderNotifs(filter='all'){
  const iconHtml={
    critical:'<svg viewBox="0 0 16 16" fill="none" stroke="#CC1F2D" stroke-width="1.8"><path d="M8 2L14 13H2L8 2Z"/><line x1="8" y1="7" x2="8" y2="10"/></svg>',
    warn:'<svg viewBox="0 0 16 16" fill="none" stroke="#C8991A" stroke-width="1.8"><circle cx="8" cy="8" r="6.5"/><line x1="8" y1="5" x2="8" y2="9"/></svg>',
    info:'<svg viewBox="0 0 16 16" fill="none" stroke="#1A6FAF" stroke-width="1.8"><circle cx="8" cy="8" r="6.5"/><line x1="8" y1="7" x2="8" y2="11"/></svg>',
  };
  const items=filter==='all'?NOTIFICATIONS:NOTIFICATIONS.filter(n=>n.type===filter);
  document.getElementById('np-body').innerHTML=items.length?items.map(n=>`
    <div class="notif-item${n.unread?' unread':''} ${n.type==='warn'?'warn-n':n.type==='info'?'info-n':''}">
      <div class="ni-icon ${n.type==='warn'?'gold':n.type==='info'?'blue':'red'}">${iconHtml[n.type]}</div>
      <div style="flex:1">
        <div class="ni-title">${n.title}</div>
        <div class="ni-msg">${n.msg}</div>
        <div class="ni-meta">${n.time}</div>
        ${n.unread?'<div class="ni-actions"><button class="btn btn-xs btn-secondary">Mark Read</button><button class="btn btn-xs btn-primary">Respond</button></div>':''}
      </div>
    </div>`).join(''):'<div style="padding:20px;text-align:center;color:var(--text3);font-size:12px">No notifications in this category</div>';
}
function toggleNotif(){
  document.getElementById('notif-panel').classList.toggle('open');
  document.getElementById('np-overlay').classList.toggle('open');
  renderNotifs();
}
function closeNotif(){
  document.getElementById('notif-panel').classList.remove('open');
  document.getElementById('np-overlay').classList.remove('open');
}
function npTab(btn,filter){
  document.querySelectorAll('.np-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active'); renderNotifs(filter);
}

// ─── SEARCH ──────────────────────────────────────────────────────────
function doSearch(q){
  const res=document.getElementById('search-results');
  if(!q||q.length<2){res.classList.remove('open');return;}
  const filtered=SEARCH_DATA.filter(d=>d.name.toLowerCase().includes(q.toLowerCase())||d.meta.toLowerCase().includes(q.toLowerCase()));
  if(!filtered.length){res.innerHTML='<div style="padding:12px 14px;font-size:12px;color:var(--text3)">No results found</div>';res.classList.add('open');return;}
  const grouped={};
  filtered.forEach(d=>{if(!grouped[d.type])grouped[d.type]=[];grouped[d.type].push(d);});
  let html='';
  Object.entries(grouped).forEach(([type,items])=>{
    html+=`<div class="sr-section">${type}</div>`;
    items.slice(0,4).forEach(d=>{
      html+=`<div class="sr-item" onclick="${d.action};closeSearch()">
        <div class="sr-dot ${d.dot}"></div>
        <div style="flex:1"><div class="sr-name">${d.name}</div><div class="sr-meta">${d.meta}</div></div>
        <span class="sr-tag">${type}</span>
      </div>`;
    });
  });
  res.innerHTML=html; res.classList.add('open');
}
function closeSearch(){
  document.getElementById('search-results').classList.remove('open');
}

// ─── MODALS ───────────────────────────────────────────────────────────
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(m=>{
  m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');});
});

// ─── CHART TABS ───────────────────────────────────────────────────────
function tabSwitch(btn){
  btn.closest('.chart-tabs').querySelectorAll('.chart-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

// ─── TOAST ────────────────────────────────────────────────────────────
function showToast(msg,bg='#1C1C1C'){
  const t=document.createElement('div');
  t.className='toast';
  t.style.background=bg; t.style.color='#fff';
  t.textContent=msg; document.body.appendChild(t);
  setTimeout(()=>t.remove(),2400);
}

// ─── MOBILE ───────────────────────────────────────────────────────────
function openMobMenu(){
  document.getElementById('sidebar').classList.add('mob-open');
  document.getElementById('mob-overlay').classList.add('open');
}
function closeMobMenu(){
  document.getElementById('sidebar').classList.remove('mob-open');
  document.getElementById('mob-overlay').classList.remove('open');
}

